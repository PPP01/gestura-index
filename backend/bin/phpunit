#!/usr/bin/env php
<?php

// PHPUnit sucht seine Konfigurationsdatei nur relativ zum aktuellen
// Arbeitsverzeichnis (getcwd()), nicht relativ zu diesem Skript.
// Damit `php backend/bin/phpunit` auch aus dem Repo-Root funktioniert,
// wechseln wir zuerst ins Projektverzeichnis.
chdir(dirname(__DIR__));

require dirname(__DIR__).'/vendor/phpunit/phpunit/phpunit';
