{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"prepare": "npm run paraglide && svelte-kit sync || echo ''",
		"check": "npm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "npm run paraglide && vitest"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.22.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/jest-dom": "^7.0.0",
		"@testing-library/svelte": "^5.4.2",
		"@types/node": "^26.1.1",
		"jsdom": "^29.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@lucide/svelte": "^1.25.0",
		"@simplewebauthn/browser": "^13.3.0"
	}
}
