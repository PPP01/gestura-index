# Statisches SvelteKit-Frontend (adapter-static mit Prerender + SPA-Fallback).
Options -MultiViews
DirectoryIndex index.html
DirectorySlash Off

<IfModule mod_rewrite.c>
	RewriteEngine On

	# 1. Vorhandene Dateien direkt ausliefern.
	RewriteCond %{REQUEST_FILENAME} -f
	RewriteRule ^ - [L]

	# 2. Trailing Slash kanonisieren (außer Wurzel): /de/ → /de, /en/docs/ → /en/docs.
	#    Ohne diese Regel liefe /de/ in das Verzeichnis de/ (kein Index → 403).
	RewriteCond %{REQUEST_URI} !^/$
	RewriteRule ^(.+)/$ /$1 [R=301,L]

	# 3. Prerenderte Seiten ohne .html-Endung ausliefern (/en → /en.html,
	#    /en/docs → /en/docs.html). MUSS vor der Verzeichnis-Regel stehen.
	RewriteCond %{REQUEST_FILENAME}.html -f
	RewriteRule ^(.+?)/?$ /$1.html [L]

	# 4. Vorhandene Verzeichnisse (v. a. die Wurzel → index.html).
	RewriteCond %{REQUEST_FILENAME} -d
	RewriteRule ^ - [L]

	# 5. Alles andere (client-gerenderte Routen wie /en/browse, /en/entry/...
	#    sowie die komplette client-only Admin-SPA unter /admin, /en/admin/...,
	#    inkl. Deep-Links wie /admin/entries/123) auf die SPA-Hülle.
	#    /admin wird bewusst NIE prerendert (siehe adapter-static-Config) –
	#    Regel 3/4 greifen dort also nie, Regel 5 übernimmt immer.
	RewriteRule ^ /200.html [L]
</IfModule>
